# PostgreSQL (e.g. Neon): postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/opencatalog?schema=public"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Single shared password for MVP admin login
ADMIN_PASSWORD="change-me"

# Optional: shown on /contact as mailto for takedowns / corrections
# CONTACT_EMAIL="you@example.com"